# Copy to `.env.local` (never commit `.env.local`).

# --- Postgres (Neon) — required for the app DB (Vercel-friendly) ---
# Create a free DB at https://neon.tech → copy the connection string (sslmode=require).
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Session cookie encryption (min 32 characters) ---
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# --- Superuser ---
SUPERUSER_USERNAME=your_admin_username
# Run: npm run hash-password -- "YourPasswordHere"
# Paste the SUPERUSER_PASSWORD_HASH_B64 line (not the raw bcrypt line — Next.js breaks `$` in .env).
SUPERUSER_PASSWORD_HASH_B64=

# Optional: map style
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/dark

# Optional: Google Places API (same key as "Maps" in GCP — enable Places API, not a separate Geocoding product).
# Used for: website on "Find location" / "Find website", and lat/lng when OpenStreetMap has no match (Text Search).
# Create a key at https://console.cloud.google.com/ → enable "Places API" (legacy) and billing. Use either name:
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=
